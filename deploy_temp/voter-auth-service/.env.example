# Database URL (PostgreSQL)
DATABASE_URL=postgresql://user:pass@host:port/dbname?sslmode=require

# JWT Secret for authentication
JWT_SECRET=your-secure-jwt-secret-key

# SMTP Configuration (Gmail)
# IMPORTANT: If you use Gmail, you MUST use an "App Password" if 2-Step Verification is enabled.
# 1. Go to Google Account -> Security -> 2-Step Verification -> App Passwords.
# 2. Generate a code for "Mail" and "Windows/Other".
# 3. Use that 16-character code as your SMTP_PASS.
SMTP_USER=sugun.rakshit@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# URLs for other services (used in production/deployment)
# ELECTION_SERVICE_URL=https://your-election-service.render.com
# PORT=8001
